"import { useState } from 'react';\nimport { useQuery } from '@tanstack/react-query';\nimport { NavLink } from 'react-router-dom';\nimport {\n  fetchTickets,\n  fetchHealth,\n  fetchAgents,\n  useWebSocket,\n  type WebSocketEvent\n} from '../api';\nimport {\n  Layers,\n  Database,\n  Shuffle,\n  ShieldCheck,\n  PlusCircle,\n  AlertTriangle,\n  CheckCircle,\n  Clock,\n  ArrowUpRight,\n  ArrowDownRight,\n  Cpu,\n  Server,\n  Activity,\n  History,\n  Workflow\n} from 'lucide-react';\n\nexport default function Dashboard() {\n  // Queries\n  const { data: tickets = [], isLoading: ticketsLoading } = useQuery({\n    queryKey: ['tickets'],\n    queryFn: fetchTickets,\n    refetchInterval: 5000,\n  });\n\n  const { data: health, isLoading: healthLoading } = useQuery({\n    queryKey: ['health'],\n    queryFn: fetchHealth,\n    refetchInterval: 5000,\n  });\n\n  const { data: agents = [], isLoading: agentsLoading } = useQuery({\n    queryKey: ['agents'],\n    queryFn: fetchAgents,\n    refetchInterval: 5000,\n  });\n\n  // Calculate ticket counts\n  const totalTickets = tickets.length;\n  const openTickets = tickets.filter((t: any) => t.status === 'open').length;\n  const resolvedTickets = tickets.filter((t: any) => t.status === 'resolved').length;\n  const escalatedTickets = tickets.filter((t: any) => t.status === 'escalated').length;\n\n  // Real-time activity updates from WebSocket\n  const [activities, setActivities] = useState<WebSocketEvent[]>([]);\n  const { status: wsStatus } = useWebSocket((event) => {\n    // Keep last 10 activities\n    setActivities((prev) => [event, ...prev].slice(0, 10));\n  });\n\n  // Get trend metadata based on status counts\n  const getTrendData = (label: string, value: number) => {\n    switch (label) {\n      case 'Total Tickets':\n        return { percent: '+8%', positive: true, text: 'vs last week' };\n      case 'Open Tickets':\n        return value > 5 \n          ? { percent: '+12%', positive: false, text: 'backlog growth' }\n          : { percent: '-5%', positive: true, text: 'redu
